<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="350" prefWidth="400" spacing="20" styleClass="login-container" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.aja.controller.LoginController">

    <padding>
        <Insets bottom="40" left="40" right="40" top="40" />
    </padding>

    <!-- Encabezado -->
    <VBox alignment="CENTER" spacing="5">
        <Label styleClass="app-title" text="AJA-Desktop" />
        <Label styleClass="app-subtitle" text="Iniciar sesión en tu cuenta" />
    </VBox>

    <!-- Formulario -->
    <VBox spacing="15" styleClass="form-container">
        <VBox spacing="5">
            <Label styleClass="field-label" text="Usuario" />
            <TextField fx:id="usernameField" maxWidth="Infinity" promptText="Introduce tu usuario" styleClass="input-field" />
            <Label fx:id="usernameErrorLabel" managed="false" styleClass="error-label" visible="false" />
        </VBox>

        <VBox spacing="5">
            <Label styleClass="field-label" text="Contraseña" />
            <PasswordField fx:id="passwordField" maxWidth="Infinity" promptText="Introduce tu contraseña" styleClass="input-field" />
            <Label fx:id="passwordErrorLabel" managed="false" styleClass="error-label" visible="false" />
        </VBox>

        <HBox alignment="CENTER_LEFT" spacing="10">
            <CheckBox fx:id="rememberCheckBox" text="Recordarme" />
        </HBox>

        <Button fx:id="loginButton" maxWidth="Infinity" onAction="#handleLogin" styleClass="login-button" text="Iniciar sesión" />

        <HBox alignment="CENTER" spacing="5">
            <Label text="¿No tienes cuenta?" />
            <Hyperlink onAction="#handleRegister" text="Regístrate ahora" />
        </HBox>
        
        <Hyperlink fx:id="forgotPasswordLink" onAction="#handleForgotPassword" style="-fx-font-size: 12px;" text="¿Olvidaste tu contraseña?" />
    </VBox>

</VBox>
